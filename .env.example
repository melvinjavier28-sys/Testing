# Lead form email delivery (Resend) — set these in Vercel:
#   Project → Settings → Environment Variables
# Copy this file to .env.local for local development (never commit real keys).

# REQUIRED — your Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=

# REQUIRED — the inbox that receives form submissions
LEAD_TO_EMAIL=

# OPTIONAL — the "from" address shown on lead emails.
# Until your domain is verified in Resend, leave this unset to use Resend's
# test sender. After verifying nationalepayment.com in Resend, set e.g.:
# LEAD_FROM_EMAIL=National e-Payment <leads@nationalepayment.com>
LEAD_FROM_EMAIL=
